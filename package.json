{
  "name": "b-board",
  "version": "0.1.0",
  "description": "BJ-Keyboard — framework-agnostic virtual keyboard UI library with multi-language support",
  "type": "module",
  "main": "./dist/bboard.umd.js",
  "module": "./dist/bboard.es.js",
  "browser": "./dist/bboard.umd.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/bboard.es.js",
      "require": "./dist/bboard.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "author": "Sadjad OUSMANE <ousmanesadjad@gmail.com>",
  "keywords": [
    "keyboard",
    "virtual-keyboard",
    "benin",
    "african-languages",
    "yoruba",
    "fon",
    "i18n"
  ],
  "scripts": {
    "dev": "vite --host",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:ci": "vitest --run --coverage",
    "test:bench": "vitest bench",
    "e2e": "playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,json,css}\"",
    "type-check": "vue-tsc --noEmit",
    "bootstrap:schemas": "tsx scripts/bootstrap-schemas.ts",
    "validate:data": "tsx scripts/validate-data.ts",
    "prepare": "husky || true",
    "docs:dev": "vitepress dev docs-site",
    "docs:build": "vitepress build docs-site",
    "docs:preview": "vitepress preview docs-site",
    "docs:api": "typedoc"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "lit": "^3.3.2",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.1.0",
    "eslint-plugin-boundaries": "^6.0.1",
    "eslint-plugin-vue": "^10.8.0",
    "fast-check": "^4.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "ts-json-schema-generator": "^2.9.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.2.0"
  }
}
