{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CompositionRulesCatalog",
  "description": "Global catalog of dead-key trigger characters used across all language profiles.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "triggers"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the catalog."
    },
    "triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["trigger", "name", "mode"],
        "properties": {
          "trigger":     { "type": "string", "minLength": 1 },
          "name":        { "type": "string", "minLength": 1 },
          "mode":        { "type": "string", "enum": ["tone", "nasal"] },
          "description": { "type": "string" }
        }
      }
    }
  }
}
